# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Postgres (lo consume docker-compose.dev.yml y Django vía DATABASE_URL)
POSTGRES_DB=wind_homes
POSTGRES_USER=wind_homes
POSTGRES_PASSWORD=wind_homes
DATABASE_URL=postgres://wind_homes:wind_homes@localhost:5432/wind_homes

# Email
# Dirección remitente que verán los usuarios. Debe estar validada como
# sender en Brevo cuando se use ese proveedor.
DEFAULT_FROM_EMAIL=Wind Homes <no-reply@wind-homes.test>

# En dev se ignora EMAIL_PROVIDER y se fuerza el backend de consola.
# En prod EMAIL_PROVIDER controla cómo se manda el correo:
#   brevo   -> API HTTPS de Brevo (recomendado, no bloqueado por DigitalOcean)
#   console -> imprime el email en stdout (útil para depurar deploys)
EMAIL_PROVIDER=brevo
BREVO_API_KEY=

# Media / static (producción)
MEDIA_ROOT=./media
STATIC_ROOT=./staticfiles

# URL pública del backend (con esquema, sin slash final). Se usa para
# construir URLs absolutas de imágenes en el correo de confirmación.
# En dev se puede dejar vacío (los clientes ven /media vía localhost);
# en prod debe apuntar al dominio público que sirve /media.
SITE_URL=
