# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Postgres (used by docker-compose.dev.yml AND read by Django via DATABASE_URL)
POSTGRES_DB=wind_homes
POSTGRES_USER=wind_homes
POSTGRES_PASSWORD=wind_homes
DATABASE_URL=postgres://wind_homes:wind_homes@localhost:5432/wind_homes

# Email (dev -> console; prod -> SMTP)
DEFAULT_FROM_EMAIL=Wind Homes <no-reply@wind-homes.test>
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Media / static (production)
MEDIA_ROOT=./media
STATIC_ROOT=./staticfiles
